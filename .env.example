# Claude Code Pool 环境变量配置
# 复制此文件为 .env 并填写真实值

# ==================== Claude API 配置 ====================

# Claude API 认证密钥（必填）
ANTHROPIC_AUTH_TOKEN=sk-ant-xxxxx

# Claude API 基础 URL（可选，使用官方 API 时可不配置）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 模型名称（可选，默认使用最新 Claude）
ANTHROPIC_MODEL=claude-sonnet-4-5

# ==================== 服务配置 ====================

# 并发任务数限制
POOL_SIZE=3

# 任务超时时间（秒）
CLAUDE_TIMEOUT=300

# 时区配置（默认东八区）
TIMEZONE_OFFSET=8

# 自动授权模式：all（全部批准）/ none（不批准）/ selective（选择性批准）
CLAUDE_AUTO_APPROVE=all

# ==================== 主动轮询模式配置 ====================
# 启用主动轮询模式后，服务会定期从外部 API 获取任务

# 是否启用轮询（true/false）
TASK_POLL_ENABLED=false

# 轮询 API 地址（获取待处理任务）
TASK_POLL_URL=https://your-api.com/api/tasks/pending

# 轮询间隔（秒）
TASK_POLL_INTERVAL=5

# 轮询 API 认证密钥（可选）
TASK_POLL_API_KEY=your-api-key

# 任务完成回调地址（可选，用于通知外部 API）
TASK_POLL_CALLBACK_URL=https://your-api.com/api/tasks/callback

# ==================== 其他配置 ====================

# 站点输出根目录
SITES_ROOT=/sites

# Claude API Key（可选，用于某些需要额外认证的场景）
CLAUDE_API_KEY=
