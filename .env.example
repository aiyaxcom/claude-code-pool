# Claude Code Pool 环境变量配置
# 复制此文件为 .env 并填写真实值

# ==================== Claude API 配置 ====================

# Claude API 认证密钥（必填）
# 也可以使用 CLAUDE_API_KEY 变量名（两者等效）
ANTHROPIC_AUTH_TOKEN=sk-ant-xxxxx

# Claude API 基础 URL（可选）
# 官方 API: https://api.anthropic.com
# 通义千问（阿里云百炼）: https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 模型名称（可选）
# 可选值：claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# ==================== 服务配置 ====================

# 并发任务数限制（建议根据 API 配额调整）
POOL_SIZE=3

# 任务超时时间（秒），超时后强制终止任务
# 建议设置为 600（10 分钟）或更长
CLAUDE_TIMEOUT=600

# 时区配置（默认东八区）
# 用于数据库时间戳，东八区为 8，西五区为 -5
TIMEZONE_OFFSET=8

# 自动授权模式：all（全部批准）/ none（不批准）/ selective（选择性批准）
# 生产环境建议使用 selective 模式
CLAUDE_AUTO_APPROVE=all

# ==================== 目录配置 ====================

# 工作目录根路径（Claude Code 在此目录下操作）
WORKSPACE_ROOT=/workspace

# 站点输出根目录（任务结果保存位置）
OUTPUT_ROOT=/sites
SITES_ROOT=/sites

# ==================== 数据库配置（可选） ====================

# 数据库连接 URL，用于持久化任务状态
# 留空则使用内存存储，重启后任务状态丢失
# PostgreSQL: postgresql+asyncpg://user:password@host:port/database
# SQLite: sqlite+aiosqlite:///tasks.db
DATABASE_URL=

# ==================== 其他配置 ====================

# Claude API Key（可选，与 ANTHROPIC_AUTH_TOKEN 等效）
CLAUDE_API_KEY=

# ==================== 已移除的配置 ====================
# 以下配置在最新版本中已移除，保留仅供参考

# 主动轮询模式已移除（v2.0+）
# TASK_POLL_ENABLED=false
# TASK_POLL_URL=https://your-api.com/api/tasks/pending
# TASK_POLL_INTERVAL=5
# TASK_POLL_API_KEY=your-api-key
# TASK_POLL_CALLBACK_URL=https://your-api.com/api/tasks/callback
