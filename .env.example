# Claude Code Pool 环境变量配置
# 复制此文件为 .env 并填写真实值

# ==================== Claude API 配置 ====================

# Claude API 认证密钥（必填）
# 也可以使用 CLAUDE_API_KEY 变量名（两者等效）
# 注意：此文件不应提交到 Git，请确保在 .gitignore 中
ANTHROPIC_AUTH_TOKEN=sk-ant-xxxxx

# Claude API 基础 URL（可选）
# 官方 API: https://api.anthropic.com
# 通义千问（阿里云百炼）: https://coding.dashscope.aliyuncs.com/apps/anthropic
# 使用国产大模型时需要配置此项
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 模型名称（可选）
# 官方 Claude: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
# 通义千问：qwen3.5-plus, qwen3-long, qwen-max
# 注意：model 字段在 settings.json 中是字符串类型，不是对象
ANTHROPIC_MODEL=claude-sonnet-4-5

# ==================== 服务配置 ====================

# 并发任务数限制（建议根据 API 配额和服务器资源调整）
# 生产环境建议设置为 3-5
POOL_SIZE=3

# 任务空闲超时时间（秒），无输出时触发超时
# 建议设置为 600（10 分钟）或更长，复杂任务可能需要更长时间
# 注意：只要任务有输出，计时器会自动重置
CLAUDE_TIMEOUT=600

# 最大总执行时间（秒），防止任务无限运行
# 默认 3600（1 小时），可根据需要调整
# 设置为 0 表示不限制（不推荐）
MAX_TOTAL_TIMEOUT=3600

# 时区配置（默认东八区）
# 用于数据库时间戳，东八区为 8，西五区为 -5
TIMEZONE_OFFSET=8

# 自动授权模式：all（全部批准）/ none（不批准）/ selective（选择性批准）
# 生产环境建议使用 selective 模式，并指定允许的工具列表
CLAUDE_AUTO_APPROVE=all

# ==================== 目录配置 ====================

# 工作目录根路径（Claude Code 在此目录下操作）
# 通常挂载项目代码目录，供 Claude 参考和修改
WORKSPACE_ROOT=/workspace

# 站点输出根目录（任务结果保存位置）
# AI 生成的站点文件保存在此目录下
OUTPUT_ROOT=/sites
SITES_ROOT=/sites

# ==================== 数据库配置（可选） ====================

# 数据库连接 URL，用于持久化任务状态
# 留空则使用内存存储，重启后任务状态丢失
# 数据库配置后，任务状态在服务重启后可恢复
#
# PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
#
# SQLite 示例:
# DATABASE_URL=sqlite+aiosqlite:///tasks.db
DATABASE_URL=

# ==================== 其他配置 ====================

# Claude API Key（可选，与 ANTHROPIC_AUTH_TOKEN 等效）
# 某些场景下可能需要使用此变量名
CLAUDE_API_KEY=
